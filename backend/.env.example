# Anthropic Claude API
ANTHROPIC_API_KEY=sk-ant-...
ANTHROPIC_MODEL=claude-sonnet-4-5-20250929
# 0.0 = deterministic, 0.3 = faithful summaries (default), 1.0 = max creativity
ANTHROPIC_TEMPERATURE=0.0

# Application
APP_NAME=transcriber
APP_ENV=development
LOG_LEVEL=INFO

# Server
HOST=0.0.0.0
PORT=8000

# CORS (comma-separated)
CORS_ORIGINS=http://localhost:3000

# Limits
#
# Claude 4.x context: 200k tokens input (~600k chars). We reserve room for
# prompts + completion, so transcripts are capped at ~200k chars (≈50k tokens)
# which fits a ~3-hour video. Longer ones use smart truncation at sentence/word
# boundaries. Increase if you have 5+ hour videos.
MAX_TRANSCRIPT_CHARS=200000
#
# Claude output: Sonnet/Haiku 4.5 support 64k tokens, Opus 4.5 supports 32k.
# 8192 tokens ≈ 6000 words — enough for detailed summaries. Increase for very
# long-form outputs.
MAX_OUTPUT_TOKENS=8192
#
DEFAULT_LANG=ru
